# Ejemplo de variables de entorno — copiar a .env (nunca commitear .env)

# GitHub (opcional — para sincronización futura)
GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_TOKEN
GITHUB_REPO=arturo-monroy/ikigai-clients-db

# Supabase (fuente de verdad OPS — solo lectura desde este repo)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY

# Cloudflare (opcional — para acceso a D1/R2)
CLOUDFLARE_ACCOUNT_ID=REPLACE_WITH_ACCOUNT_ID
CLOUDFLARE_API_TOKEN=REPLACE_WITH_TOKEN

# Notificaciones (opcional)
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_CHAT_ID
